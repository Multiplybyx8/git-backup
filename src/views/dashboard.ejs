<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Git Backup Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard.css" />
</head>
<body class="dashboard-page">
  <header class="topbar compact-topbar">
    <div class="topbar-inner">
      <div class="topbar-title">
        <h1>Git Backup</h1>
        <span class="status-badge status-badge-online">Online</span>
        <% if (typeof portalUser !== 'undefined' && portalUser) { %>
          <span class="topbar-user"><%= portalUser.user_fullnameTH || portalUser.user_fullnameEN || portalUser.user_email || portalUser.employee_code || 'Portal user' %></span>
        <% } %>
        <span class="topbar-meta">Port <%= config.port %> · <%= config.timezone %></span>
      </div>
      <form method="POST" action="/dashboard/logout">
        <button type="submit" class="btn btn-ghost btn-sm">ออกจากระบบ</button>
      </form>
    </div>
  </header>

  <main class="dashboard-shell">
    <section class="status-strip">
      <div class="status-chip"><span class="chip-label">GitHub</span><strong><%= config.owner %></strong></div>
      <div class="status-chip"><span class="chip-label">DAYS</span><strong><%= config.days %> วัน</strong></div>
      <div class="status-chip status-chip-wide"><span class="chip-label">Cron</span><strong><%= config.cronScheduleLabel %></strong></div>
      <div class="status-chip">
        <span class="chip-label">LINE</span>
        <span class="mini-badge <%= config.lineConfigured ? 'mini-badge-ok' : 'mini-badge-warn' %>">
          <%= config.lineConfigured ? 'OK' : '—' %>
        </span>
      </div>
      <% config.driveAccounts.forEach(function(account) { %>
        <div class="status-chip">
          <span class="chip-label"><%= account.label %></span>
          <span class="mini-badge <%= account.configured ? 'mini-badge-ok' : 'mini-badge-warn' %>">
            <% if (account.authMode === 'oauth') { %>
              <%= account.oauthConnected ? 'OAuth' : 'Connect' %>
            <% } else { %>
              <%= account.configured ? 'OK' : '—' %>
            <% } %>
          </span>
        </div>
      <% }); %>
    </section>

    <nav class="section-nav" aria-label="เมนูหลัก">
      <button type="button" class="section-nav-btn active" data-section="backup">
        <span class="section-nav-icon">⬆</span>
        <span class="section-nav-text">
          <strong>สำรองข้อมูล</strong>
          <small>Clone จาก GitHub → อัปโหลด Drive</small>
        </span>
      </button>
      <button type="button" class="section-nav-btn" data-section="drive-backup">
        <span class="section-nav-icon">📦</span>
        <span class="section-nav-text">
          <strong>ไฟล์ Backup</strong>
          <small>ดูไฟล์ .zip ตามโครงสร้าง ปี/เดือน/วัน</small>
        </span>
      </button>
      <button type="button" class="section-nav-btn" data-section="drive-all">
        <span class="section-nav-icon">📁</span>
        <span class="section-nav-text">
          <strong>ไฟล์ทั้งหมด</strong>
          <small>ดูทุกโฟลเดอร์และไฟล์ตามวันที่สร้าง</small>
        </span>
      </button>
    </nav>

    <section class="job-banner" id="jobStatusCard" hidden>
      <div class="spinner spinner-sm"></div>
      <div class="job-banner-text">
        <strong id="jobType">กำลัง Backup...</strong>
        <span id="jobCurrent" class="muted">—</span>
        <span id="jobStarted" class="muted small"></span>
      </div>
    </section>

    <div class="section-view" id="sectionBackup">
      <section class="panel backup-workspace">
        <div class="panel-head panel-head-accent panel-head-backup">
          <div>
            <h2>สำรองข้อมูล Repository</h2>
            <p class="panel-subtitle">เลือก Drive → เลือก Folder → ตั้งช่วงวันที่ → Preview หรือเริ่ม Backup</p>
          </div>
        </div>

        <div class="workspace-grid-4">
          <div class="backup-step workspace-step" id="backupDriveStep">
            <div class="step-label">1. Google Drive <span class="required">*</span></div>
            <div class="drive-tiles workspace-scroll" id="backupDriveTiles">
              <%- include('partials/drive-account-tiles', { accounts: config.driveAccounts, inputName: 'backupDriveAccount', showOAuthInfo: true }) %>
            </div>
            <p id="backupDriveRequiredHint" class="inline-alert warn">เลือก Google Drive ก่อน</p>
            <p id="backupDriveSelectedHint" class="inline-alert ok" hidden></p>
          </div>

          <div class="backup-step workspace-step backup-step-locked" id="backupFolderStep">
            <div class="step-label">2. Folder <span class="required">*</span></div>
            <div class="drive-tiles workspace-scroll" id="backupFolderTiles">
              <%- include('partials/drive-folder-tiles', { accounts: config.driveAccounts, inputName: 'backupFolder' }) %>
            </div>
            <p id="backupFolderPickDriveHint" class="inline-alert muted">เลือก Drive ก่อน</p>
            <p id="backupFolderRequiredHint" class="inline-alert warn" hidden>เลือก Folder ก่อน</p>
            <p id="backupFolderSelectedHint" class="inline-alert ok" hidden></p>
          </div>

          <div class="backup-step workspace-step backup-step-locked workspace-settings-col" id="backupSettingsStep">
            <div class="step-label">3. ตั้งค่า Backup</div>
            <div class="workspace-settings-fields">
              <div class="form-group compact">
                <label>Owner</label>
                <input type="text" id="rangeOwner" value="<%= config.owner %>" disabled />
              </div>
              <div class="form-row workspace-date-row">
                <div class="form-group compact">
                  <label>ตั้งแต่</label>
                  <input type="date" id="rangeFrom" disabled />
                </div>
                <div class="form-group compact">
                  <label>ถึง</label>
                  <input type="date" id="rangeTo" disabled />
                </div>
              </div>
            </div>
            <div class="form-actions">
              <div class="checkbox-row compact">
                <label><input type="checkbox" id="rangeNormal" checked disabled /> Normal</label>
                <label><input type="checkbox" id="rangeMirror" checked disabled /> Mirror</label>
              </div>
              <div class="button-row">
                <button type="button" class="btn btn-secondary btn-sm" id="btnPreview" disabled>Preview</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnBackupRange" disabled>เริ่ม Backup</button>
              </div>
            </div>
            <div class="cron-settings-block">
              <div class="cron-settings-head">Auto Backup (Cron)</div>
              <p class="cron-settings-current" id="cronBackupLabel">
                <%= config.cronBackup.configured ? config.cronBackup.driveAccountLabel : "ยังไม่ได้ตั้งค่า" %>
              </p>
              <p class="cron-settings-meta" id="cronBackupMeta">
                <%= config.cronScheduleLabel %> · <%= config.cronBackup.source === 'dashboard' ? 'ตั้งจาก Dashboard' : (config.cronBackup.source === 'env' ? 'จาก .env' : 'ค่าเริ่มต้น') %>
              </p>
              <button type="button" class="btn btn-secondary btn-sm" id="btnSaveCronSettings" disabled>
                ใช้ Drive + Folder ที่เลือก
              </button>
            </div>
          </div>

          <div class="workspace-output-col output-panel">
            <div class="panel-head panel-head-tabs workspace-output-head">
              <button type="button" class="tab-btn active" data-tab="preview">Preview</button>
              <button type="button" class="tab-btn" data-tab="result">ผลลัพธ์</button>
            </div>

            <div class="panel-body workspace-output-body" id="tabPreview">
              <p class="tab-desc">จาก GitHub — ยังไม่ clone</p>
              <div id="previewEmpty" class="empty-state">เลือกวันที่แล้วกด Preview</div>
              <div id="previewTable" hidden>
                <p id="previewSummary" class="summary compact-summary"></p>
                <div class="table-scroll">
                  <table class="compact-table">
                    <thead><tr><th>#</th><th>Repo</th><th>Pushed</th></tr></thead>
                    <tbody id="previewBody"></tbody>
                  </table>
                </div>
              </div>
            </div>

            <div class="panel-body workspace-output-body" id="tabResult" hidden>
              <p class="tab-desc">หลังรัน Backup จริง</p>
              <div id="resultEmpty" class="empty-state">กด "เริ่ม Backup"</div>
              <div id="resultLoading" class="empty-state" hidden>
                <div class="spinner spinner-sm"></div>
                <span>กำลัง Backup...</span>
              </div>
              <div id="resultPanel" hidden>
                <p id="resultSummary" class="summary compact-summary"></p>
                <div class="table-scroll">
                  <table class="compact-table">
                    <thead><tr><th>Repo</th><th>N</th><th>M</th><th>สถานะ</th></tr></thead>
                    <tbody id="resultBody"></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="section-view" id="sectionDrive" hidden>
      <section class="panel backup-workspace browse-workspace">
        <div class="panel-head panel-head-accent panel-head-drive">
          <div>
            <h2>ค้นหาไฟล์ Backup (.zip)</h2>
            <p class="panel-subtitle">เลือก Drive → เลือก Folder → ค้นหาตามโครงสร้าง ปี/เดือน/วัน</p>
          </div>
        </div>

        <div class="workspace-grid-4">
          <div class="backup-step workspace-step" id="browseDriveStep">
            <div class="step-label">1. Google Drive <span class="required">*</span></div>
            <div class="drive-tiles workspace-scroll" id="browseDriveTiles">
              <%- include('partials/drive-account-tiles', { accounts: config.driveAccounts, inputName: 'browseDriveAccount' }) %>
            </div>
            <p id="browseDriveRequiredHint" class="inline-alert warn">เลือก Google Drive ก่อน</p>
            <p id="browseDriveSelectedHint" class="inline-alert ok" hidden></p>
          </div>

          <div class="backup-step workspace-step backup-step-locked" id="browseFolderStep">
            <div class="step-label">2. Folder <span class="required">*</span></div>
            <div class="drive-tiles workspace-scroll" id="browseFolderTiles">
              <%- include('partials/drive-folder-tiles', { accounts: config.driveAccounts, inputName: 'browseFolder' }) %>
            </div>
            <p id="browseFolderPickDriveHint" class="inline-alert muted">เลือก Drive ก่อน</p>
            <p id="browseFolderRequiredHint" class="inline-alert warn" hidden>เลือก Folder ก่อน</p>
            <p id="browseFolderSelectedHint" class="inline-alert ok" hidden></p>
          </div>

          <div class="backup-step workspace-step browse-step-locked workspace-settings-col" id="browseSettingsStep">
            <div class="step-label">3. ช่วงวันที่</div>
            <div class="form-row workspace-date-row">
              <div class="form-group compact">
                <label>ตั้งแต่</label>
                <input type="date" id="browseFrom" disabled />
              </div>
              <div class="form-group compact">
                <label>ถึง</label>
                <input type="date" id="browseTo" disabled />
              </div>
            </div>
            <div class="form-actions">
              <p class="browse-note">เฉพาะ <strong>.zip</strong> ใน <code>ปี/เดือน/วัน</code></p>
              <div class="button-row">
                <button type="button" class="btn btn-primary btn-sm" id="btnBrowseDrive" disabled>ค้นหาไฟล์</button>
              </div>
            </div>
          </div>

          <div class="workspace-output-col output-panel">
            <div class="panel-head panel-head-tabs workspace-output-head">
              <span class="workspace-output-title">รายการไฟล์</span>
            </div>
            <div class="panel-body workspace-output-body">
              <div id="browseEmpty" class="empty-state">เลือก Drive, Folder และวันที่ แล้วกดค้นหา</div>
              <div id="browseLoading" class="empty-state" hidden>
                <div class="spinner spinner-sm"></div>
                <span>กำลังโหลด...</span>
              </div>
              <div id="browsePanel" hidden>
                <p id="browseSummary" class="summary compact-summary"></p>
                <div class="table-scroll">
                  <table class="compact-table browse-table-narrow">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>ไฟล์</th>
                        <th>โฟลเดอร์</th>
                        <th>ขนาด</th>
                        <th>อัปโหลด</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody id="browseBody"></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="section-view" id="sectionDriveAll" hidden>
      <section class="panel backup-workspace browse-workspace">
        <div class="panel-head panel-head-accent panel-head-drive-all">
          <div>
            <h2>ดูไฟล์ทั้งหมดบน Google Drive</h2>
            <p class="panel-subtitle">เลือก Drive → เลือก Folder → ค้นหาทุกโฟลเดอร์และไฟล์ตามวันที่สร้าง (created date)</p>
          </div>
        </div>

        <div class="workspace-grid-4">
          <div class="backup-step workspace-step" id="driveAllDriveStep">
            <div class="step-label">1. Google Drive <span class="required">*</span></div>
            <div class="drive-tiles workspace-scroll" id="driveAllDriveTiles">
              <%- include('partials/drive-account-tiles', { accounts: config.driveAccounts, inputName: 'driveAllDriveAccount' }) %>
            </div>
            <p id="driveAllDriveRequiredHint" class="inline-alert warn">เลือก Google Drive ก่อน</p>
            <p id="driveAllDriveSelectedHint" class="inline-alert ok" hidden></p>
          </div>

          <div class="backup-step workspace-step backup-step-locked" id="driveAllFolderStep">
            <div class="step-label">2. Folder <span class="required">*</span></div>
            <div class="drive-tiles workspace-scroll" id="driveAllFolderTiles">
              <%- include('partials/drive-folder-tiles', { accounts: config.driveAccounts, inputName: 'driveAllFolder' }) %>
            </div>
            <p id="driveAllFolderPickDriveHint" class="inline-alert muted">เลือก Drive ก่อน</p>
            <p id="driveAllFolderRequiredHint" class="inline-alert warn" hidden>เลือก Folder ก่อน</p>
            <p id="driveAllFolderSelectedHint" class="inline-alert ok" hidden></p>
          </div>

          <div class="backup-step workspace-step browse-step-locked workspace-settings-col" id="driveAllSettingsStep">
            <div class="step-label">3. ช่วงวันที่สร้าง</div>
            <div class="form-row workspace-date-row">
              <div class="form-group compact">
                <label>ตั้งแต่</label>
                <input type="date" id="driveAllFrom" disabled />
              </div>
              <div class="form-group compact">
                <label>ถึง</label>
                <input type="date" id="driveAllTo" disabled />
              </div>
            </div>
            <div class="form-actions">
              <p class="browse-note">แสดง <strong>โฟลเดอร์และไฟล์ทั้งหมด</strong> ที่สร้างในช่วงวันที่นี้ ภายใต้ Folder ที่เลือก</p>
              <div class="button-row">
                <button type="button" class="btn btn-primary btn-sm" id="btnDriveAllBrowse" disabled>ค้นหา</button>
              </div>
            </div>
          </div>

          <div class="workspace-output-col output-panel">
            <div class="panel-head panel-head-tabs workspace-output-head">
              <span class="workspace-output-title">รายการทั้งหมด</span>
            </div>
            <div class="panel-body workspace-output-body">
              <div id="driveAllEmpty" class="empty-state">เลือก Drive, Folder และวันที่ แล้วกดค้นหา</div>
              <div id="driveAllLoading" class="empty-state" hidden>
                <div class="spinner spinner-sm"></div>
                <span>กำลังสแกน Drive...</span>
              </div>
              <div id="driveAllPanel" hidden>
                <p id="driveAllSummary" class="summary compact-summary"></p>
                <div class="table-scroll">
                  <table class="compact-table drive-all-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>ชนิด</th>
                        <th>ชื่อ</th>
                        <th>พาธ</th>
                        <th>ขนาด</th>
                        <th>สร้างเมื่อ</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody id="driveAllBody"></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <div id="toast" class="toast" hidden></div>

  <div id="oauthModal" class="oauth-modal" hidden>
    <div class="oauth-modal-backdrop" id="oauthModalBackdrop"></div>
    <div class="oauth-modal-card" role="dialog" aria-labelledby="oauthModalTitle">
      <button type="button" class="oauth-modal-close" id="oauthModalClose" aria-label="ปิด">×</button>
      <h3 id="oauthModalTitle" class="oauth-modal-title">OAuth Config</h3>
      <p class="oauth-modal-desc">ใส่ Redirect URI ใน Google Cloud Console ก่อน Connect บน production</p>

      <div class="oauth-modal-field">
        <label>Redirect URI <span class="oauth-modal-hint">(Authorized redirect URIs)</span></label>
        <div class="oauth-modal-row">
          <input type="text" id="oauthModalRedirect" class="oauth-modal-input" readonly />
          <button type="button" class="btn btn-secondary btn-xs" id="oauthModalCopyRedirect">Copy</button>
        </div>
      </div>

      <div id="oauthModalTokenBlock" hidden>
        <div class="oauth-modal-field">
          <label>Refresh Token <span id="oauthModalTokenSource" class="oauth-modal-hint"></span></label>
          <div class="oauth-modal-row">
            <input type="text" id="oauthModalToken" class="oauth-modal-input" readonly />
            <button type="button" class="btn btn-secondary btn-xs" id="oauthModalCopyToken">Copy</button>
          </div>
        </div>
        <div class="oauth-modal-field">
          <label>สำหรับ .env (optional)</label>
          <div class="oauth-modal-row">
            <input type="text" id="oauthModalEnvLine" class="oauth-modal-input" readonly />
            <button type="button" class="btn btn-secondary btn-xs" id="oauthModalCopyEnv">Copy</button>
          </div>
        </div>
      </div>

      <p id="oauthModalNoToken" class="oauth-modal-note">
        ยังไม่มี token — กด <strong>เชื่อมต่อ Google Drive</strong> บน server แล้ว token จะถูกเก็บใน <code>data/oauth-tokens.json</code>
      </p>
      <p class="oauth-modal-note">
        Token หมดอายุ / revoke → Connect ใหม่บน production (วิธี B) ด้วย Redirect URI ด้านบน
      </p>
    </div>
  </div>

  <script>
    const config = <%- JSON.stringify(config) %>;
    let pollTimer = null;
    let selectedBackupDriveAccount = null;
    let selectedBackupDriveDestination = null;
    let selectedBrowseDriveAccount = null;
    let selectedBrowseDriveDestination = null;
    let selectedDriveAllDriveAccount = null;
    let selectedDriveAllDriveDestination = null;
    const driveAccounts = config.driveAccounts || [];
    let oauthDataByAccount = {};
    const backupFolderStep = document.getElementById("backupFolderStep");
    const backupSettingsStep = document.getElementById("backupSettingsStep");
    const backupDriveRequiredHint = document.getElementById("backupDriveRequiredHint");
    const backupDriveSelectedHint = document.getElementById("backupDriveSelectedHint");
    const backupFolderPickDriveHint = document.getElementById("backupFolderPickDriveHint");
    const backupFolderRequiredHint = document.getElementById("backupFolderRequiredHint");
    const backupFolderSelectedHint = document.getElementById("backupFolderSelectedHint");
    const browseFolderStep = document.getElementById("browseFolderStep");
    const browseSettingsStep = document.getElementById("browseSettingsStep");
    const browseDriveRequiredHint = document.getElementById("browseDriveRequiredHint");
    const browseDriveSelectedHint = document.getElementById("browseDriveSelectedHint");
    const browseFolderPickDriveHint = document.getElementById("browseFolderPickDriveHint");
    const browseFolderRequiredHint = document.getElementById("browseFolderRequiredHint");
    const browseFolderSelectedHint = document.getElementById("browseFolderSelectedHint");
    const driveAllFolderStep = document.getElementById("driveAllFolderStep");
    const driveAllSettingsStep = document.getElementById("driveAllSettingsStep");
    const driveAllDriveRequiredHint = document.getElementById("driveAllDriveRequiredHint");
    const driveAllDriveSelectedHint = document.getElementById("driveAllDriveSelectedHint");
    const driveAllFolderPickDriveHint = document.getElementById("driveAllFolderPickDriveHint");
    const driveAllFolderRequiredHint = document.getElementById("driveAllFolderRequiredHint");
    const driveAllFolderSelectedHint = document.getElementById("driveAllFolderSelectedHint");
    const backupFieldIds = ["rangeOwner", "rangeFrom", "rangeTo", "rangeNormal", "rangeMirror", "btnPreview", "btnBackupRange"];
    const browseFieldIds = ["browseFrom", "browseTo", "btnBrowseDrive"];
    const driveAllFieldIds = ["driveAllFrom", "driveAllTo", "btnDriveAllBrowse"];

    const switchSection = (section) => {
      document.querySelectorAll(".section-nav-btn").forEach((btn) => {
        btn.classList.toggle("active", btn.dataset.section === section);
      });
      document.getElementById("sectionBackup").hidden = section !== "backup";
      document.getElementById("sectionDrive").hidden = section !== "drive-backup";
      document.getElementById("sectionDriveAll").hidden = section !== "drive-all";
    };

    document.querySelectorAll(".section-nav-btn").forEach((btn) => {
      btn.addEventListener("click", () => switchSection(btn.dataset.section));
    });

    const setBackupFolderStepEnabled = (enabled) => {
      backupFolderStep.classList.toggle("backup-step-locked", !enabled);
    };

    const setBackupFormEnabled = (enabled) => {
      backupSettingsStep.classList.toggle("backup-step-locked", !enabled);
      backupFieldIds.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.disabled = !enabled;
      });
      const saveCronBtn = document.getElementById("btnSaveCronSettings");
      if (saveCronBtn) saveCronBtn.disabled = !enabled;
    };

    const setBrowseFolderStepEnabled = (enabled) => {
      browseFolderStep.classList.toggle("backup-step-locked", !enabled);
    };

    const setBrowseFormEnabled = (enabled) => {
      browseSettingsStep.classList.toggle("browse-step-locked", !enabled);
      browseFieldIds.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.disabled = !enabled;
      });
    };

    const setDriveAllFolderStepEnabled = (enabled) => {
      driveAllFolderStep.classList.toggle("backup-step-locked", !enabled);
    };

    const setDriveAllFormEnabled = (enabled) => {
      driveAllSettingsStep.classList.toggle("browse-step-locked", !enabled);
      driveAllFieldIds.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.disabled = !enabled;
      });
    };

    const showFolderGroup = (containerId, accountId) => {
      const container = document.getElementById(containerId);
      if (!container) return;

      container.querySelectorAll(".folder-tiles-group").forEach((group) => {
        const isActive = Boolean(accountId) && group.dataset.account === accountId;
        group.hidden = !isActive;
        if (!isActive) {
          group.querySelectorAll('input[type="radio"]').forEach((input) => {
            input.checked = false;
          });
        }
      });
    };

    const getAccountById = (accountId) => driveAccounts.find((item) => item.id === accountId);

    const getFolderByDestinationId = (accountId, destinationId) => {
      const account = getAccountById(accountId);
      return account?.folders?.find((item) => item.destinationId === destinationId) || null;
    };

    const updateBackupOAuthActions = (selectedAccountId) => {
