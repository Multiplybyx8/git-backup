      return selectedDriveAllDriveDestination;
    };

    const switchTab = (tab) => {
      document.querySelectorAll(".tab-btn").forEach((btn) => {
        btn.classList.toggle("active", btn.dataset.tab === tab);
      });
      document.getElementById("tabPreview").hidden = tab !== "preview";
      document.getElementById("tabResult").hidden = tab !== "result";
    };

    const showResultLoading = () => {
      switchSection("backup");
      switchTab("result");
      document.getElementById("resultEmpty").hidden = true;
      document.getElementById("resultLoading").hidden = false;
      document.getElementById("resultPanel").hidden = true;
    };

    const hideResultLoading = () => {
      document.getElementById("resultLoading").hidden = true;
    };

    document.querySelectorAll(".tab-btn").forEach((btn) => {
      btn.addEventListener("click", () => switchTab(btn.dataset.tab));
    });

    const toast = (msg, isError = false) => {
      const el = document.getElementById("toast");
      el.textContent = msg;
      el.className = "toast" + (isError ? " toast-error" : "");
      el.hidden = false;
      setTimeout(() => { el.hidden = true; }, 4000);
    };

    const formatDate = (iso) => {
      if (!iso) return "—";
      return new Date(iso).toLocaleString("th-TH", { timeZone: "Asia/Bangkok", dateStyle: "short", timeStyle: "short" });
    };

    const escapeHtml = (value) => String(value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");

    const downloadIconSvg = `<svg class="icon-download" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>`;

    const downloadDriveFile = async (btn) => {
      const url = btn.dataset.url;
      const filename = btn.dataset.filename;
      if (!url || btn.disabled) return;

      btn.disabled = true;
      btn.classList.add("is-loading");
      btn.setAttribute("aria-busy", "true");

      try {
        const res = await fetch(url);
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || "ดาวน์โหลดไม่สำเร็จ");
        }

        const blob = await res.blob();
        const objectUrl = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = objectUrl;
        link.download = filename || "backup.zip";
        link.click();
        URL.revokeObjectURL(objectUrl);
      } catch (e) {
        toast(e.message, true);
      } finally {
        btn.disabled = false;
        btn.classList.remove("is-loading");
        btn.removeAttribute("aria-busy");
      }
    };

    const toDateInputValue = (date) => {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    };

    const setDefaultDates = () => {
      const days = parseInt(config.days, 10) || 1;
      const today = new Date();
      const fromDate = new Date();
      fromDate.setDate(today.getDate() - days);
      const toValue = toDateInputValue(today);
      const fromValue = toDateInputValue(fromDate);

      document.getElementById("rangeTo").value = toValue;
      document.getElementById("rangeFrom").value = fromValue;
      document.getElementById("browseTo").value = toValue;
      document.getElementById("browseFrom").value = fromValue;
      document.getElementById("driveAllTo").value = toValue;
      document.getElementById("driveAllFrom").value = fromValue;
    };

    const renderJobStatus = (status) => {
      const card = document.getElementById("jobStatusCard");
      if (!status.running) {
        card.hidden = true;
        return;
      }
      card.hidden = false;
      document.getElementById("jobType").textContent = status.type === "cron" ? "Backup (Cron)" : "Backup";
      document.getElementById("jobCurrent").textContent = status.currentRepo ? `· ${status.currentRepo}` : "";
      document.getElementById("jobStarted").textContent = status.startedAt ? `· ${formatDate(status.startedAt)}` : "";
    };

    const renderLastResult = (status) => {
      if (!status.lastResult) return;
      const result = status.lastResult;
      hideResultLoading();
      switchSection("backup");
      switchTab("result");
      document.getElementById("resultEmpty").hidden = true;
      document.getElementById("resultPanel").hidden = false;
      document.getElementById("resultSummary").textContent =
        `${result.message} · Drive: ${result.driveAccountLabel || "—"} · ${formatDate(result.finishedAt)}`;

      const rows = [];
      (result.processed || []).forEach((item) => {
        rows.push(`<tr>
          <td>${item.repo}</td>
          <td>${item.normal ? "✅" : "—"}</td>
          <td>${item.mirror ? "✅" : "—"}</td>
          <td class="ok">สำเร็จ</td>
        </tr>`);
      });
      (result.skipped || []).forEach((item) => {
        rows.push(`<tr>
          <td>${item.repo}</td>
          <td>—</td>
          <td>—</td>
          <td class="fail">${item.reason || "ข้าม"}</td>
        </tr>`);
      });
      document.getElementById("resultBody").innerHTML = rows.join("") ||
        `<tr><td colspan="4" class="muted">ไม่มี repository ในรอบนี้</td></tr>`;
    };

    const pollStatus = async () => {
      try {
        const res = await fetch("/dashboard/api/status");
        const status = await res.json();
        renderJobStatus(status);
        if (status.running) {
          showResultLoading();
        } else if (pollTimer) {
          hideResultLoading();
          renderLastResult(status);
          clearInterval(pollTimer);
          pollTimer = null;
        }
      } catch (e) {
        console.error(e);
      }
    };

    const startPolling = () => {
      if (pollTimer) clearInterval(pollTimer);
      pollTimer = setInterval(pollStatus, 2000);
      pollStatus();
    };

    const postJson = async (url, body) => {
      const res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || data.message || "Request failed");
      return data;
    };

    document.getElementById("btnPreview").addEventListener("click", async () => {
      const from = document.getElementById("rangeFrom").value;
      const to = document.getElementById("rangeTo").value;
      if (!from || !to) return toast("กรุณาเลือกช่วงวันที่", true);

      try {
        const res = await fetch(`/dashboard/api/repos/preview?from=${from}&to=${to}`);
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Preview failed");

        switchTab("preview");
        document.getElementById("previewEmpty").hidden = true;
        document.getElementById("previewTable").hidden = false;
        document.getElementById("previewSummary").textContent =
          `จะ backup ${data.total} repository · ${from} → ${to}`;
        document.getElementById("previewBody").innerHTML = (data.repositories || []).map((repo, i) =>
          `<tr><td>${i + 1}</td><td>${repo.name}</td><td>${formatDate(repo.pushedAt)}</td></tr>`
        ).join("") || `<tr><td colspan="3" class="muted">ไม่พบ</td></tr>`;
      } catch (e) {
        toast(e.message, true);
      }
    });

    document.getElementById("btnBackupRange").addEventListener("click", async () => {
      const from = document.getElementById("rangeFrom").value;
      const to = document.getElementById("rangeTo").value;
      if (!from || !to) return toast("กรุณาเลือกช่วงวันที่", true);

      try {
        const data = await postJson("/dashboard/api/backup/range", {
          driveDestination: getSelectedBackupDriveDestination(),
          from, to,
          includeNormal: document.getElementById("rangeNormal").checked,
          includeMirror: document.getElementById("rangeMirror").checked
        });
        toast(data.message);
        showResultLoading();
        startPolling();
      } catch (e) {
        toast(e.message, true);
      }
    });

    let cronBackupSettings = config.cronBackup || {};
    const cronSourceLabels = {
      dashboard: "ตั้งจาก Dashboard",
      env: "จาก .env",
      default: "ค่าเริ่มต้น"
    };

    const renderCronSettings = (settings = cronBackupSettings) => {
      cronBackupSettings = settings;
      document.getElementById("cronBackupLabel").textContent = settings.configured
        ? settings.driveAccountLabel
        : "ยังไม่ได้ตั้งค่า";
      const sourceLabel = cronSourceLabels[settings.source] || settings.source || "—";
      document.getElementById("cronBackupMeta").textContent =
        `${config.cronScheduleLabel} · ${sourceLabel}`;
    };

    document.getElementById("btnSaveCronSettings").addEventListener("click", async () => {
      try {
        const data = await postJson("/dashboard/api/settings/cron", {
          driveDestination: getSelectedBackupDriveDestination(),
          includeNormal: document.getElementById("rangeNormal").checked,
          includeMirror: document.getElementById("rangeMirror").checked
        });
        renderCronSettings(data);
        toast("บันทึกค่า Auto Backup (Cron) แล้ว");
      } catch (e) {
        toast(e.message, true);
      }
    });

    document.getElementById("btnBrowseDrive").addEventListener("click", async () => {
      const from = document.getElementById("browseFrom").value;
      const to = document.getElementById("browseTo").value;
      if (!from || !to) return toast("กรุณาเลือกช่วงวันที่", true);

      document.getElementById("browseEmpty").hidden = true;
      document.getElementById("browsePanel").hidden = true;
      document.getElementById("browseLoading").hidden = false;

      try {
        const driveDestination = getSelectedBrowseDriveDestination();
        const res = await fetch(
          `/dashboard/api/drive/files?from=${from}&to=${to}&driveDestination=${encodeURIComponent(driveDestination)}`
        );
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "ค้นหาไฟล์ไม่สำเร็จ");

        document.getElementById("browseLoading").hidden = true;
        document.getElementById("browsePanel").hidden = false;

        const scan = data.scan || {};
        let summary = `พบ ${data.total} ไฟล์ .zip · ${data.driveAccountLabel} · ${from} → ${to}`;
        if (data.total === 0) {
          summary += ` · ตรวจ ${scan.datesChecked || 0} วัน`;
          if (scan.dayFoldersFound) {
            summary += ` · พบโฟลเดอร์วัน ${scan.dayFoldersFound} แต่ไม่มีไฟล์ .zip`;
          } else {
            summary += ` · ไม่พบโฟลเดอร์ ปี/เดือน/วัน ในช่วงนี้`;
          }
        }
        document.getElementById("browseSummary").textContent = summary;
        document.getElementById("browseBody").innerHTML = (data.files || []).map((file, i) => {
          const downloadUrl =
            `/dashboard/api/drive/files/${encodeURIComponent(file.id)}/download?driveDestination=${encodeURIComponent(driveDestination)}&folderPath=${encodeURIComponent(file.folderPath)}`;
          return `<tr>
            <td>${i + 1}</td>
            <td>${escapeHtml(file.name)}</td>
            <td class="mono">${escapeHtml(file.folderPath)}</td>
            <td>${escapeHtml(file.sizeLabel || "—")}</td>
            <td>${formatDate(file.createdTime)}</td>
            <td class="td-actions">
              <button
                type="button"
                class="btn-icon btn-download"
                data-url="${downloadUrl}"
                data-filename="${escapeHtml(file.name)}"
                title="ดาวน์โหลด"
                aria-label="ดาวน์โหลด ${escapeHtml(file.name)}"
              >${downloadIconSvg}</button>
            </td>
          </tr>`;
        }).join("") || `<tr><td colspan="6" class="muted">${data.total === 0
          ? (data.scan?.dayFoldersFound
            ? "พบโฟลเดอร์วันแล้ว แต่ไม่มีไฟล์ .zip — แสดงเฉพาะไฟล์ zip"
            : "ไม่พบโฟลเดอร์ ปี/เดือน/วัน ในช่วงวันที่นี้ — ตรวจว่าเลือก Folder ถูกและมีโครงสร้าง 2026/06/18")
          : "ไม่พบไฟล์ในช่วงวันที่นี้"}</td></tr>`;
      } catch (e) {
        document.getElementById("browseLoading").hidden = true;
        document.getElementById("browseEmpty").hidden = false;
        toast(e.message, true);
      }
    });

    document.getElementById("browseBody").addEventListener("click", (event) => {
      const btn = event.target.closest(".btn-download");
      if (btn) downloadDriveFile(btn);
    });

    document.getElementById("btnDriveAllBrowse").addEventListener("click", async () => {
      const from = document.getElementById("driveAllFrom").value;
      const to = document.getElementById("driveAllTo").value;
      if (!from || !to) return toast("กรุณาเลือกช่วงวันที่", true);

      document.getElementById("driveAllEmpty").hidden = true;
      document.getElementById("driveAllPanel").hidden = true;
      document.getElementById("driveAllLoading").hidden = false;

      try {
        const driveDestination = getSelectedDriveAllDriveDestination();
        const res = await fetch(
          `/dashboard/api/drive/items?from=${from}&to=${to}&driveDestination=${encodeURIComponent(driveDestination)}`
        );
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "ค้นหาไม่สำเร็จ");

        document.getElementById("driveAllLoading").hidden = true;
        document.getElementById("driveAllPanel").hidden = false;

        const scan = data.scan || {};
        let summary = `พบ ${data.total} รายการ`;
        if (typeof data.folderCount === "number" || typeof data.fileCount === "number") {
          summary += ` (${data.folderCount || 0} โฟลเดอร์ · ${data.fileCount || 0} ไฟล์)`;
        }
        summary += ` · ${data.driveAccountLabel} · ${from} → ${to}`;
        if (data.total === 0) {
          summary += ` · สแกน ${scan.foldersScanned || 0} โฟลเดอร์`;
        }
        document.getElementById("driveAllSummary").textContent = summary;
        document.getElementById("driveAllBody").innerHTML = (data.items || []).map((item, i) => {
          const typeLabel = item.isFolder ? "📁" : "📄";
          const downloadUrl = item.isFolder
            ? ""
            : `/dashboard/api/drive/files/${encodeURIComponent(item.id)}/download?driveDestination=${encodeURIComponent(driveDestination)}&mode=all`;
          const actionCell = item.isFolder
            ? (item.webViewLink
              ? `<a href="${escapeHtml(item.webViewLink)}" target="_blank" rel="noopener" class="btn btn-ghost btn-xs">เปิด</a>`
              : "")
            : `<button
                type="button"
                class="btn-icon btn-download"
                data-url="${downloadUrl}"
                data-filename="${escapeHtml(item.name)}"
                title="ดาวน์โหลด"
                aria-label="ดาวน์โหลด ${escapeHtml(item.name)}"
              >${downloadIconSvg}</button>`;
          return `<tr class="${item.isFolder ? "row-folder" : "row-file"}">
            <td>${i + 1}</td>
            <td>${typeLabel}</td>
            <td>${escapeHtml(item.name)}</td>
            <td class="mono truncate-cell">${escapeHtml(item.path || "—")}</td>
            <td>${escapeHtml(item.sizeLabel || "—")}</td>
            <td>${formatDate(item.createdTime)}</td>
            <td class="td-actions">${actionCell}</td>
          </tr>`;
        }).join("") || `<tr><td colspan="7" class="muted">ไม่พบโฟลเดอร์หรือไฟล์ที่สร้างในช่วงวันที่นี้</td></tr>`;
      } catch (e) {
        document.getElementById("driveAllLoading").hidden = true;
        document.getElementById("driveAllEmpty").hidden = false;
        toast(e.message, true);
      }
    });

    document.getElementById("driveAllBody").addEventListener("click", (event) => {
      const btn = event.target.closest(".btn-download");
      if (btn) downloadDriveFile(btn);
    });

    document.querySelectorAll('input[name="backupDriveAccount"]').forEach((input) => {
      input.addEventListener("change", updateBackupDriveSelection);
    });

    document.getElementById("backupFolderTiles").addEventListener("change", (event) => {
      if (event.target.matches('input[name="backupFolder"]')) {
        updateBackupFolderSelection();
      }
    });

    document.querySelectorAll('input[name="browseDriveAccount"]').forEach((input) => {
      input.addEventListener("change", updateBrowseDriveSelection);
    });

    document.getElementById("browseFolderTiles").addEventListener("change", (event) => {
      if (event.target.matches('input[name="browseFolder"]')) {
        updateBrowseFolderSelection();
      }
    });

    document.querySelectorAll('input[name="driveAllDriveAccount"]').forEach((input) => {
      input.addEventListener("change", updateDriveAllDriveSelection);
    });

    document.getElementById("driveAllFolderTiles").addEventListener("change", (event) => {
      if (event.target.matches('input[name="driveAllFolder"]')) {
        updateDriveAllFolderSelection();
      }
    });

    setDefaultDates();
    setBackupFolderStepEnabled(false);
    setBackupFormEnabled(false);
    setBrowseFolderStepEnabled(false);
    setBrowseFormEnabled(false);
    setDriveAllFolderStepEnabled(false);
    setDriveAllFormEnabled(false);
    updateBackupDriveSelection();
    updateBrowseDriveSelection();
    updateDriveAllDriveSelection();
    renderCronSettings();

    const copyText = async (text, label = "คัดลอกแล้ว") => {
      try {
        await navigator.clipboard.writeText(text);
        toast(label);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
        toast(label);
      }
    };

    const bindFolderCopyButtons = (containerId) => {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.addEventListener("click", (event) => {
        const btn = event.target.closest(".btn-folder-copy");
        if (!btn || btn.disabled) return;
        event.preventDefault();
        event.stopPropagation();
        const folderId = btn.dataset.folderId;
        if (folderId) copyText(folderId, "คัดลอก Folder ID แล้ว");
      });
    };

    bindFolderCopyButtons("backupFolderTiles");
    bindFolderCopyButtons("browseFolderTiles");
    bindFolderCopyButtons("driveAllFolderTiles");

    const renderOAuthTokens = (accounts) => {
      oauthDataByAccount = {};
      (accounts || []).forEach((account) => {
        oauthDataByAccount[account.id] = account;
      });
    };

    const openOAuthModal = (accountId) => {
      const fromConfig = driveAccounts.find((item) => item.id === accountId);
      const fromApi = oauthDataByAccount[accountId] || {};
      if (!fromConfig || fromConfig.authMode !== "oauth") return;

      const redirectUri = fromApi.redirectUri || fromConfig.redirectUri || "—";
      const refreshToken = fromApi.refreshToken || null;
      const envKey = fromApi.refreshTokenEnvKey || fromConfig.refreshTokenEnvKey || "GOOGLE_REFRESH_TOKEN";
      const envLine = refreshToken ? `${envKey}="${refreshToken}"` : "";

      document.getElementById("oauthModalTitle").textContent = `${fromConfig.label} — OAuth`;
      document.getElementById("oauthModalRedirect").value = redirectUri;

      const tokenBlock = document.getElementById("oauthModalTokenBlock");
      const noToken = document.getElementById("oauthModalNoToken");
      if (refreshToken) {
        tokenBlock.hidden = false;
        noToken.hidden = true;
        document.getElementById("oauthModalToken").value = refreshToken;
        document.getElementById("oauthModalEnvLine").value = envLine;
        const source = fromApi.refreshTokenSource === "env" ? "จาก .env" : "จาก data/oauth-tokens.json";
        document.getElementById("oauthModalTokenSource").textContent = `(${source})`;
      } else {
        tokenBlock.hidden = true;
        noToken.hidden = false;
      }

      document.getElementById("oauthModal").hidden = false;
    };

    const closeOAuthModal = () => {
      document.getElementById("oauthModal").hidden = true;
    };

    const loadOAuthTokens = async () => {
      try {
        const res = await fetch("/dashboard/api/oauth/status");
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to load OAuth status");
        renderOAuthTokens(data.accounts);
      } catch (e) {
        console.error(e);
      }
    };

    const handleOAuthQuery = () => {
      const params = new URLSearchParams(window.location.search);
      const success = params.get("oauth_success");
      const error = params.get("oauth_error");
      if (success) {
        toast(`เชื่อมต่อ Google Drive สำเร็จ (${success})`);
        loadOAuthTokens();
      }
      if (error) toast(decodeURIComponent(error.replace(/\+/g, " ")), true);
      if (success || error) window.history.replaceState({}, "", "/dashboard");
    };

    const disconnectOAuth = async (accountId, accountLabel) => {
      const label = accountLabel || accountId;
      const confirmed = confirm(
        `ยืนยันยกเลิกการเชื่อมต่อ Google Drive?\n\n` +
        `บัญชี: ${label}\n\n` +
        `หลังยกเลิกจะ backup ไม่ได้จนกว่าจะกด "เชื่อมต่อ Google Drive" ใหม่\n` +
        `(ถ้ามี GOOGLE_REFRESH_TOKEN ใน .env ต้อง comment บรรทัดนั้นด้วย)`
      );
      if (!confirmed) return;
      try {
        const res = await fetch("/dashboard/api/oauth/disconnect", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ driveAccount: accountId })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Disconnect failed");
        toast(data.message, Boolean(data.envTokenActive));
        window.location.reload();
      } catch (e) {
        toast(e.message, true);
      }
    };

    const bindOAuthInfoButtons = (containerId) => {
      const container = document.getElementById(containerId);
      if (!container) return;

      container.addEventListener("click", (event) => {
        const infoBtn = event.target.closest(".btn-oauth-info");
        if (!infoBtn || infoBtn.disabled) return;
        event.preventDefault();
        event.stopPropagation();
        openOAuthModal(infoBtn.dataset.account);
      });
    };

    document.querySelectorAll(".btn-oauth-disconnect").forEach((btn) => {
      btn.addEventListener("click", (event) => {
        if (btn.disabled) return;
        event.preventDefault();
        event.stopPropagation();
        disconnectOAuth(btn.dataset.account, btn.dataset.label);
      });
    });

    bindOAuthInfoButtons("backupDriveTiles");

    document.getElementById("oauthModalClose").addEventListener("click", closeOAuthModal);
    document.getElementById("oauthModalBackdrop").addEventListener("click", closeOAuthModal);
    document.getElementById("oauthModalCopyRedirect").addEventListener("click", () => {
      copyText(document.getElementById("oauthModalRedirect").value, "คัดลอก Redirect URI แล้ว");
    });
    document.getElementById("oauthModalCopyToken").addEventListener("click", () => {
      copyText(document.getElementById("oauthModalToken").value, "คัดลอก refresh_token แล้ว");
    });
    document.getElementById("oauthModalCopyEnv").addEventListener("click", () => {
      copyText(document.getElementById("oauthModalEnvLine").value, "คัดลอกบรรทัด .env แล้ว");
    });

    handleOAuthQuery();
    loadOAuthTokens();
  </script>
</body>
</html>
